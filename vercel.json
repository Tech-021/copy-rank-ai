{
  "crons": [
    {
      "path": "/api/article-jobs/process",
      "schedule": "* * * * *"
    }
  ],
  "functions": {
    "app/api/scraper/route.js": {
      "maxDuration": 300,
      "memory": 1024
    },
    "app/api/extract-keywords/route.js": {
      "maxDuration": 300,
      "memory": 1024
    },
    "app/api/onboarding/route.js": {
      "maxDuration": 300,
      "memory": 1024
    },
    "app/api/**/route.js": {
      "maxDuration": 300
    },
    "app/api/**/route.ts": {
      "maxDuration": 300
    }
  }
}




