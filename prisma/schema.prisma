generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // or mysql/sqlite depending on your DB
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String
  employee  Employee?
}

model Employee {
  id               String     @id @default(cuid())
  userId           String     @unique
  firstName        String
  lastName         String
  department       String
  position         String
  salary           Float?
  hireDate         DateTime
  phoneNumber      String?
  address          String?
  emergencyContact String?
  status           String
  user             User       @relation(fields: [userId], references: [id])
  checkIns         CheckIn[]
  leaveBalances    LeaveBalance[]
  leaveRequests    LeaveRequest[]
}

model CheckIn {
  id          String   @id @default(cuid())
  employeeId  String
  checkInTime DateTime
  checkOutTime DateTime?
  totalHours  Float?
  notes       String?
  location    String?
  employee    Employee @relation(fields: [employeeId], references: [id])
}

model LeaveBalance {
  id          String   @id @default(cuid())
  employeeId  String
  leaveType   String
  totalDays   Int
  usedDays    Int
  remainingDays Int
  year        Int
  employee    Employee @relation(fields: [employeeId], references: [id])
}

model LeaveRequest {
  id          String   @id @default(cuid())
  employeeId  String
  leaveType   String
  startDate   DateTime
  endDate     DateTime
  totalDays   Int
  reason      String
  status      String
  approvedBy  String?
  approvedAt  DateTime?
  employee    Employee @relation(fields: [employeeId], references: [id])
}

model Settings {
  id                  String @id @default(cuid())
  companyName         String
  standardWorkHours   Int
  annualLeaveDays     Int
  slackEnabled        Boolean
  emailNotifications  Boolean
  sessionTimeout      Int
  passwordPolicy      String
}
